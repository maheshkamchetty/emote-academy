---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-teal-950 text-teal-50 py-12 md:py-16 mt-auto">
	<div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-8">
		
		<div class="md:col-span-1">
			<a href="/" class="text-2xl font-extrabold text-white tracking-tighter flex items-center gap-1 mb-4">
				<span class="text-rose-500 text-3xl">è</span>mote academy
			</a>
			<p class="text-teal-200 text-sm leading-relaxed mb-6">
				A nurturing environment for your child's growth, emphasizing emotional intelligence, creative exploration, and screen-free education.
			</p>
			<div class="flex gap-4">
				<a href="#" class="text-teal-300 hover:text-white transition" aria-label="Facebook">
					<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.53 11.16 6 12.96 6c.86 0 1.76.15 1.76.15v1.94h-.99c-.98 0-1.28.61-1.28 1.23V12h2.39l-.38 3h-2v6.8C18.56 20.87 22 16.84 22 12z"/></svg>
				</a>
				<a href="#" class="text-teal-300 hover:text-white transition" aria-label="Instagram">
					<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85C2.38 3.86 3.9 2.31 7.15 2.23c1.27-.06 1.65-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07 2.76.27.27 2.76.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.29 2.69 6.78 6.98 6.98 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c4.29-.2 6.78-2.69 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.29-2.69-6.78-6.98-6.98C15.67.01 15.26 0 12 0zm0 5.84A6.16 6.16 0 1018.16 12 6.16 6.16 0 0012 5.84zm0 10.16A4 4 0 1116 12a4 4 0 01-4 4zm5.22-9.62a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/></svg>
				</a>
			</div>
		</div>

		<div>
			<h4 class="text-white font-bold mb-4 uppercase text-sm tracking-wider">Explore</h4>
			<ul class="space-y-3 text-teal-200 text-sm border-l-2 border-teal-800 pl-4">
				<li><a href="/programs" class="hover:text-white hover:underline transition">Our Programs</a></li>
				<li><a href="/evening-program" class="hover:text-white hover:underline transition">Evening Adventures</a></li>
				<li><a href="/educators" class="hover:text-white hover:underline transition">Educators</a></li>
				<li><a href="/admissions" class="hover:text-white hover:underline transition">Admissions</a></li>
			</ul>
		</div>

		<div class="md:col-span-2">
			<h4 class="text-white font-bold mb-4 uppercase text-sm tracking-wider">Contact Us</h4>
			<div class="space-y-3 text-teal-200 text-sm">
				<p class="flex items-start gap-3">
					<svg class="w-5 h-5 fill-current mt-0.5 text-rose-500 shrink-0" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
					7406 Wild Eagle Street,<br />San Antonio, TX, USA
				</p>
				<p class="flex items-center gap-3">
					<svg class="w-5 h-5 fill-current text-rose-500 shrink-0" viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>
					<a href="tel:210-330-9966" class="hover:text-white transition">210-330-9966</a>
				</p>
				<p class="flex items-center gap-3">
					<svg class="w-5 h-5 fill-current text-rose-500 shrink-0" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
					<a href="mailto:prek@emoteacademy.com" class="hover:text-white transition">prek@emoteacademy.com</a>
				</p>
			</div>
		</div>

	</div>
	
	<div class="max-w-6xl mx-auto px-6 mt-12 pt-6 border-t border-teal-800 text-center text-teal-400 text-xs">
		<p>&copy; {currentYear} by èmote academy. All rights reserved.</p>
	</div>
</footer>