---
// src/components/Header.astro
---

<div class="bg-rose-500 text-white text-center py-2.5 px-4 text-sm font-medium">
	🎉 STEAM on Stage! Spring Break Camp is enrolling now. 
	<a href="/spring-break-camp" class="underline font-bold hover:text-rose-100 transition ml-1">Learn More &rarr;</a>
</div>

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
	<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
		
		<a href="/" class="flex items-center gap-2 group">
			<svg class="h-10 w-auto shrink-0 transition-transform group-hover:scale-110" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M20 6.5C20 5.12 18.88 4 17.5 4C16.12 4 15 5.12 15 6.5H11C10.17 6.5 9.5 7.17 9.5 8V12C8.12 12 7 13.12 7 14.5C7 15.88 8.12 17 9.5 17V21C9.5 21.83 10.17 22.5 11 22.5H15C15 23.88 16.12 25 17.5 25C18.88 25 20 23.88 20 22.5H24C24.83 22.5 25.5 21.83 25.5 21V17C26.88 17 28 15.88 28 14.5C28 13.12 26.88 12 25.5 12V8C25.5 7.17 24.83 6.5 24 6.5H20Z" fill="#fcd34d"/>
				<path d="M18.5 4.5C18.5 3.12 17.38 2 16 2C14.62 2 13.5 3.12 13.5 4.5H9.5C8.67 4.5 8 5.17 8 6V10C6.62 10 5.5 11.12 5.5 12.5C5.5 13.88 6.62 15 8 15V19C8 19.83 8.67 20.5 9.5 20.5H13.5C13.5 21.88 14.62 23 16 23C17.38 23 18.5 21.88 18.5 20.5H22.5C23.33 20.5 24 19.83 24 19V15C25.38 15 26.5 13.88 26.5 12.5C26.5 11.12 25.38 10 24 10V6C24 5.17 23.33 4.5 22.5 4.5H18.5Z" fill="#fef3c7" stroke="#0f766e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				<circle cx="13.5" cy="11.5" r="1.5" fill="#0f766e"/>
				<circle cx="18.5" cy="11.5" r="1.5" fill="#0f766e"/>
				<path d="M13.5 15.5Q16 18 18.5 15.5" stroke="#0f766e" stroke-width="2" stroke-linecap="round"/>
			</svg>
			<span class="text-2xl font-extrabold text-teal-900 tracking-tighter">èmote academy</span>
		</a>

		<nav class="hidden lg:flex items-center gap-8">
			
			<div class="relative group py-6">
				<button class="flex items-center gap-1 text-gray-600 hover:text-teal-700 font-bold transition focus:outline-none">
					Programs
					<svg class="w-4 h-4 mt-0.5 text-gray-400 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
				</button>
				<div class="absolute top-full left-0 w-64 bg-white rounded-2xl shadow-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0 z-50 overflow-hidden p-2">
					<a href="/programs" class="block px-4 py-3 text-sm font-bold text-gray-700 hover:bg-teal-50 hover:text-teal-800 rounded-xl transition">Full-Day Pre-K</a>
					<a href="/evening-program" class="block px-4 py-3 text-sm font-bold text-gray-700 hover:bg-teal-50 hover:text-teal-800 rounded-xl transition">Evening Program</a>
					<a href="/spring-break-camp" class="block px-4 py-3 text-sm font-bold text-rose-600 hover:bg-rose-50 rounded-xl italic transition">Spring Break Camp</a>
				</div>
			</div>

			<div class="relative group py-6">
				<button class="flex items-center gap-1 text-gray-600 hover:text-teal-700 font-bold transition focus:outline-none">
					About
					<svg class="w-4 h-4 mt-0.5 text-gray-400 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
				</button>
				<div class="absolute top-full left-0 w-56 bg-white rounded-2xl shadow-xl border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0 z-50 overflow-hidden p-2">
					<a href="/our-model" class="block px-4 py-3 text-sm font-bold text-gray-700 hover:bg-teal-50 hover:text-teal-800 rounded-xl transition">Our Model</a>
					<a href="/educators" class="block px-4 py-3 text-sm font-bold text-gray-700 hover:bg-teal-50 hover:text-teal-800 rounded-xl transition">Educators</a>
					<a href="/calendar" class="block px-4 py-3 text-sm font-bold text-gray-700 hover:bg-teal-50 hover:text-teal-800 rounded-xl transition border-t border-slate-50 mt-1">School Calendar</a>
				</div>
			</div>

            <a href="/contact" class="text-gray-600 hover:text-teal-700 font-bold transition">Contact</a>
		</nav>

		<div class="hidden lg:flex items-center gap-5">
			<a href="/admissions" class="bg-rose-500 text-white px-8 py-3 rounded-full font-bold hover:bg-rose-600 transition shadow-lg shadow-rose-200 hover:-translate-y-0.5">Enroll Now</a>
		</div>

		<button id="mobile-menu-btn" class="lg:hidden text-gray-600 p-2 focus:outline-none">
			<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
		</button>
	</div>

	<div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 absolute w-full shadow-2xl z-50">
		<div class="flex flex-col px-8 py-10 space-y-8">
			<div class="space-y-4">
				<p class="text-xs font-black text-slate-400 uppercase tracking-widest">Programs</p>
				<a href="/programs" class="block text-2xl font-extrabold text-gray-800">Full-Day Pre-K</a>
				<a href="/evening-program" class="block text-2xl font-extrabold text-gray-800">Evening Program</a>
				<a href="/spring-break-camp" class="block text-2xl font-extrabold text-rose-500">Spring Break Camp</a>
			</div>
			<div class="h-px bg-gray-100 w-full"></div>
			<div class="space-y-4">
				<p class="text-xs font-black text-slate-400 uppercase tracking-widest">About Us</p>
				<a href="/our-model" class="block text-xl font-bold text-gray-600">Our Model</a>
				<a href="/educators" class="block text-xl font-bold text-gray-600">Educators</a>
				<a href="/calendar" class="block text-xl font-bold text-gray-600">School Calendar</a>
			</div>
			<a href="/admissions" class="block w-full bg-rose-500 text-white text-center py-5 rounded-2xl font-bold text-xl shadow-xl">Enroll Now</a>
		</div>
	</div>
</header>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => {
		menu?.classList.toggle('hidden');
	});
</script>