---
// src/components/Header.astro
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
	<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
		
		<a href="/" class="flex items-center gap-2 group">
			<svg class="h-10 w-auto shrink-0 transition-transform group-hover:scale-110" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M20 6.5C20 5.12 18.88 4 17.5 4C16.12 4 15 5.12 15 6.5H11C10.17 6.5 9.5 7.17 9.5 8V12C8.12 12 7 13.12 7 14.5C7 15.88 8.12 17 9.5 17V21C9.5 21.83 10.17 22.5 11 22.5H15C15 23.88 16.12 25 17.5 25C18.88 25 20 23.88 20 22.5H24C24.83 22.5 25.5 21.83 25.5 21V17C26.88 17 28 15.88 28 14.5C28 13.12 26.88 12 25.5 12V8C25.5 7.17 24.83 6.5 24 6.5H20Z" fill="#fcd34d"/>
				
				<path d="M18.5 4.5C18.5 3.12 17.38 2 16 2C14.62 2 13.5 3.12 13.5 4.5H9.5C8.67 4.5 8 5.17 8 6V10C6.62 10 5.5 11.12 5.5 12.5C5.5 13.88 6.62 15 8 15V19C8 19.83 8.67 20.5 9.5 20.5H13.5C13.5 21.88 14.62 23 16 23C17.38 23 18.5 21.88 18.5 20.5H22.5C23.33 20.5 24 19.83 24 19V15C25.38 15 26.5 13.88 26.5 12.5C26.5 11.12 25.38 10 24 10V6C24 5.17 23.33 4.5 22.5 4.5H18.5Z" fill="#fef3c7" stroke="#0f766e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				
				<circle cx="13.5" cy="11.5" r="1.5" fill="#0f766e"/>
				<circle cx="18.5" cy="11.5" r="1.5" fill="#0f766e"/>
				<path d="M13.5 15.5Q16 18 18.5 15.5" stroke="#0f766e" stroke-width="2" stroke-linecap="round"/>
				
				<path d="M4 7V9M4 23V25M28 7V9M28 23V25M3 8H5M3 24H5M27 8H29M27 24H29" stroke="#0f766e" stroke-width="2" stroke-linecap="round"/>
				<circle cx="2" cy="16" r="1" fill="#0f766e"/>
				<circle cx="30" cy="16" r="1" fill="#0f766e"/>
				<circle cx="16" cy="28" r="1" fill="#0f766e"/>
				<circle cx="16" cy="1" r="1" fill="#0f766e"/>
			</svg>
			<span class="text-2xl font-extrabold text-teal-900 tracking-tighter">èmote academy</span>
		</a>

		<nav class="hidden lg:flex items-center gap-8">
			<a href="/programs" class="text-gray-600 hover:text-teal-700 font-medium transition">Our Programs</a>
			<a href="/evening-program" class="text-gray-600 hover:text-teal-700 font-medium transition">Evening Program</a>
			<a href="/our-model" class="text-gray-600 hover:text-teal-700 font-medium transition">Our Model</a>
			<a href="/educators" class="text-gray-600 hover:text-teal-700 font-medium transition">Educators</a>
		</nav>

		<div class="hidden lg:flex items-center gap-5">
			<a href="/contact" class="text-teal-700 font-bold hover:text-teal-800 transition">Contact</a>
			<a href="/admissions" class="bg-rose-500 text-white px-6 py-2.5 rounded-full font-bold hover:bg-rose-600 transition shadow-sm hover:shadow-md">Enroll Now</a>
		</div>

		<button id="mobile-menu-btn" class="lg:hidden text-gray-600 hover:text-teal-700 focus:outline-none" aria-label="Toggle Menu">
			<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
		</button>
	</div>

	<div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 absolute w-full shadow-2xl">
		<div class="flex flex-col px-6 py-6 space-y-5">
			<a href="/programs" class="text-gray-700 font-medium hover:text-teal-700 text-lg">Our Programs</a>
			<a href="/evening-program" class="text-gray-700 font-medium hover:text-teal-700 text-lg">Evening Program</a>
			<a href="/our-model" class="text-gray-700 font-medium hover:text-teal-700 text-lg">Our Model</a>
			<a href="/educators" class="text-gray-700 font-medium hover:text-teal-700 text-lg">Educators</a>
			<div class="h-px bg-gray-100 w-full my-2"></div>
			<a href="/contact" class="text-gray-700 font-medium hover:text-teal-700 text-lg">Contact Us</a>
			<a href="/admissions" class="bg-rose-500 text-white text-center px-6 py-4 rounded-xl font-bold hover:bg-rose-600 text-lg">Enroll Now</a>
		</div>
	</div>
</header>

<script>
	// Simple script to toggle the mobile menu open and closed
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	
	btn?.addEventListener('click', () => {
		menu?.classList.toggle('hidden');
	});
</script>