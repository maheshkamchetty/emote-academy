---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | èmote academy San Antonio" description="Get in touch with èmote academy. Located at 7406 Wild Eagle Street, San Antonio, TX. Call or email us to schedule a tour.">
	
	<section class="bg-teal-900 py-20 text-center px-6">
		<div class="max-w-3xl mx-auto">
			<h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-6">
				Get in <span class="text-amber-400">Touch</span>
			</h1>
			<p class="text-xl text-teal-100 leading-relaxed">
				Have questions about our curriculum or evening programs? We are here to help.
			</p>
		</div>
	</section>

	<section class="py-20 px-6 bg-white flex-grow">
		<div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
			
			<div>
				<h2 class="text-3xl font-bold text-teal-900 mb-8">Reach Out Directly</h2>
				
				<div class="space-y-6 mb-10">
					<div class="flex items-start gap-4">
						<div class="w-12 h-12 rounded-full bg-teal-50 flex items-center justify-center text-teal-700 shrink-0">
							<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
						</div>
						<div>
							<h4 class="font-bold text-gray-900 text-lg">Our Location</h4>
							<p class="text-gray-600">7406 Wild Eagle Street<br />San Antonio, TX, USA</p>
						</div>
					</div>

					<div class="flex items-start gap-4">
						<div class="w-12 h-12 rounded-full bg-rose-50 flex items-center justify-center text-rose-500 shrink-0">
							<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>
						</div>
						<div>
							<h4 class="font-bold text-gray-900 text-lg">Phone</h4>
							<a href="tel:210-330-9966" class="text-gray-600 hover:text-teal-700 transition">210-330-9966</a>
						</div>
					</div>

					<div class="flex items-start gap-4">
						<div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center text-amber-600 shrink-0">
							<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
						</div>
						<div>
							<h4 class="font-bold text-gray-900 text-lg">Email</h4>
							<a href="mailto:prek@emoteacademy.com" class="text-gray-600 hover:text-teal-700 transition">prek@emoteacademy.com</a>
						</div>
					</div>
				</div>

				<div class="w-full h-64 bg-gray-200 rounded-3xl overflow-hidden shadow-sm border border-gray-100">
					<iframe 
						width="100%" 
						height="100%" 
						style="border:0" 
						loading="lazy" 
						allowfullscreen 
						src="https://maps.google.com/maps?width=100%25&amp;height=600&amp;hl=en&amp;q=7406%20Wild%20Eagle%20Street,%20San%20Antonio,%20TX+(%C3%A8mote%20academy)&amp;t=&amp;z=15&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"
						title="èmote academy location map"
					></iframe>
				</div>
			</div>

			<div class="bg-white rounded-3xl p-8 md:p-10 border border-gray-100 shadow-xl shadow-teal-900/5 h-fit text-left">
				<h2 class="text-2xl font-bold text-teal-900 mb-6">Send a Message</h2>
				
				<form class="flex flex-col gap-5" onsubmit="event.preventDefault(); alert('Form submission ready for backend connection!');">
					<div class="flex flex-col">
						<label for="name" class="text-sm font-semibold text-gray-700 mb-2">Your Name</label>
						<input type="text" id="name" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white" required>
					</div>
					
					<div class="flex flex-col">
						<label for="contactEmail" class="text-sm font-semibold text-gray-700 mb-2">Email Address</label>
						<input type="email" id="contactEmail" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white" required>
					</div>

					<div class="flex flex-col">
						<label for="message" class="text-sm font-semibold text-gray-700 mb-2">How can we help you?</label>
						<textarea id="message" rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white resize-none" required></textarea>
					</div>

					<button type="submit" class="w-full py-4 mt-2 bg-teal-700 text-white rounded-xl font-bold text-lg hover:bg-teal-800 transition shadow-md">
						Send Message
					</button>
				</form>
			</div>

		</div>
	</section>

</Layout>