---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Spring Break Camp | èmote academy San Antonio" description="Join our STEAM on Stage! Spring Break Camp. A unique blend of science, technology, engineering, arts, math, and theatre for ages 3-11.">
	
	<section class="bg-rose-500 py-24 text-center px-6">
		<div class="max-w-4xl mx-auto">
			<span class="bg-white/20 text-white px-4 py-1.5 rounded-full text-sm font-bold tracking-wider uppercase mb-6 inline-block">Spring Break Camp</span>
			<h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-6">
				<span class="text-amber-300">STEAM</span> on Stage!
			</h1>
			<p class="text-xl text-rose-50 leading-relaxed max-w-2xl mx-auto font-medium">
				Where Science, Technology, Engineering, Arts, and Math meet the magic of theatre. 
			</p>
		</div>
	</section>

	<section class="py-20 px-6 bg-slate-50">
		<div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16">
			
			<div class="bg-white p-10 rounded-3xl shadow-lg border-t-8 border-teal-500">
				<div class="inline-block bg-teal-100 text-teal-800 font-bold px-4 py-1.5 rounded-full text-sm mb-6">Ages 3–5</div>
				<h2 class="text-3xl font-bold text-teal-900 mb-2">Preschool Track</h2>
				<h3 class="text-xl font-semibold text-gray-500 mb-8">Little Inventors & Storybook Scientists</h3>
				
				<p class="text-gray-600 leading-relaxed mb-8">
					A hands-on, imaginative journey focused on sensory play and dramatic storytelling to spark early curiosity.
				</p>

				<ul class="space-y-4 mb-10">
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-teal-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						<span class="text-gray-700 font-medium"><strong>Weather Wizards:</strong> Discover the science of weather through creative movement and art.</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-teal-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						<span class="text-gray-700 font-medium"><strong>Space Explorers:</strong> Build rockets and embark on a dramatic storytelling journey to the stars.</span>
					</li>
				</ul>
			</div>

			<div class="bg-white p-10 rounded-3xl shadow-lg border-t-8 border-amber-500">
				<div class="inline-block bg-amber-100 text-amber-800 font-bold px-4 py-1.5 rounded-full text-sm mb-6">Ages 6–11</div>
				<h2 class="text-3xl font-bold text-teal-900 mb-2">Elementary Track</h2>
				<h3 class="text-xl font-semibold text-gray-500 mb-8">Inventors Theatre Lab</h3>
				
				<p class="text-gray-600 leading-relaxed mb-8">
					An immersive experience where students tackle real problem-solving, script writing, and stage performance.
				</p>

				<ul class="space-y-4 mb-10">
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						<span class="text-gray-700 font-medium"><strong>Engineering Challenge:</strong> Design, build, and test set pieces and functional props.</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
						<span class="text-gray-700 font-medium"><strong>Tech & Special Effects:</strong> Learn the science behind stage lighting, sound effects, and theatre tech.</span>
					</li>
				</ul>
			</div>

		</div>

		<div class="max-w-3xl mx-auto text-center mt-20">
			<h3 class="text-2xl font-bold text-teal-900 mb-6">Ready for a week of discovery and drama?</h3>
			<a href="/admissions" class="inline-block bg-teal-700 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-teal-800 transition shadow-md">Reserve Your Spot Today</a>
		</div>
	</section>

</Layout>