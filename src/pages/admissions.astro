---
import Layout from '../layouts/Layout.astro';

const steps = [
  {
    number: "01",
    title: "Schedule a Tour",
    description: "Experience our screen-free environment firsthand. See our classrooms and learn about our unique emotional intelligence curriculum."
  },
  {
    number: "02",
    title: "Meet the Team",
    description: "Sit down with Punnami and our educators to discuss your child's specific needs, dietary preferences, and how we can best support their growth."
  },
  {
    number: "03",
    title: "Submit Application",
    description: "Complete our straightforward enrollment forms and secure your child's spot in either our daytime Pre-K or Evening Adventures program."
  },
  {
    number: "04",
    title: "Welcome Home",
    description: "Attend our orientation session and prepare for your child's exciting first day at èmote academy!"
  }
];
---

<Layout title="Admissions | èmote academy San Antonio" description="Start your child's journey with èmote academy. Learn about our enrollment process and schedule a tour of our San Antonio facility today.">
	
	<section class="bg-teal-900 py-20 text-center px-6">
		<div class="max-w-3xl mx-auto">
			<h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-6">
				Join Our <span class="text-amber-400">Family</span>
			</h1>
			<p class="text-xl text-teal-100 leading-relaxed">
				We are excited to welcome you to èmote academy. Discover our straightforward enrollment process and schedule your visit today.
			</p>
		</div>
	</section>

	<section class="py-20 px-6 bg-white flex-grow">
		<div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">
			
			<div>
				<h2 class="text-3xl font-bold text-teal-900 mb-10">The Enrollment Process</h2>
				<div class="space-y-12">
					{steps.map((step) => (
						<div class="flex gap-6">
							<div class="flex-shrink-0">
								<div class="w-16 h-16 rounded-full bg-rose-100 flex items-center justify-center text-rose-500 font-bold text-2xl border-4 border-white shadow-md">
									{step.number}
								</div>
							</div>
							<div>
								<h3 class="text-xl font-bold text-gray-900 mb-2">{step.title}</h3>
								<p class="text-gray-600 leading-relaxed">{step.description}</p>
							</div>
						</div>
					))}
				</div>
			</div>

			<div class="bg-amber-50 rounded-3xl p-8 md:p-10 border border-amber-100 shadow-sm h-fit">
				<h2 class="text-2xl font-bold text-teal-900 mb-2">Request Information</h2>
				<p class="text-gray-600 mb-8 text-sm">Fill out the form below, and our team will get back to you within 24 hours.</p>
				
				<form class="space-y-6" onsubmit="event.preventDefault(); alert('Form submission will be connected to your backend soon!');">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div>
							<label for="firstName" class="block text-sm font-semibold text-gray-700 mb-2">Parent's First Name</label>
							<input type="text" id="firstName" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition" required>
						</div>
						<div>
							<label for="lastName" class="block text-sm font-semibold text-gray-700 mb-2">Parent's Last Name</label>
							<input type="text" id="lastName" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition" required>
						</div>
					</div>
					
					<div>
						<label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email Address</label>
						<input type="email" id="email" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition" required>
					</div>

					<div>
						<label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">Phone Number</label>
						<input type="tel" id="phone" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition">
					</div>
					
					<div>
						<label for="program" class="block text-sm font-semibold text-gray-700 mb-2">Interested Program</label>
						<select id="program" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-white">
							<option>Pre-K (Daytime)</option>
							<option>Evening Adventures</option>
							<option>Not Sure Yet</option>
						</select>
					</div>

					<button type="submit" class="w-full py-4 bg-teal-700 text-white rounded-xl font-bold text-lg hover:bg-teal-800 transition shadow-md">
						Send Inquiry
					</button>
				</form>
			</div>

		</div>
	</section>

</Layout>
