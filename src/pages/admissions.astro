---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admissions & Enrollment | èmote academy San Antonio" description="Begin your child's journey at èmote academy. Schedule a tour, learn about our enrollment process, and secure your spot in our Pre-K or Evening programs.">
	
	<section class="bg-teal-900 py-20 text-center px-6">
		<div class="max-w-3xl mx-auto">
			<h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-6">
				Join Our <span class="text-amber-400">Family</span>
			</h1>
			<p class="text-xl text-teal-100 leading-relaxed">
				Take the first step toward a nurturing, screen-free educational experience for your child.
			</p>
		</div>
	</section>

	<section class="py-20 px-6 bg-slate-50 flex-grow">
		<div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16">
			
			<div class="lg:col-span-5">
				<h2 class="text-3xl font-bold text-teal-900 mb-8">The Enrollment Process</h2>
				
				<div class="space-y-8 relative before:absolute before:inset-0 before:ml-6 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-300 before:to-transparent">
					
					<div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
						<div class="flex items-center justify-center w-12 h-12 rounded-full border-4 border-white bg-teal-600 text-white font-bold shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-md relative z-10">
							1
						</div>
						<div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] p-6 bg-white rounded-2xl shadow-sm border border-gray-100">
							<h3 class="font-bold text-gray-900 text-lg mb-2">Inquire & Tour</h3>
							<p class="text-gray-600 text-sm">Fill out the form to let us know about your family. We will schedule a secure, in-person tour of our San Antonio facility.</p>
						</div>
					</div>

					<div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
						<div class="flex items-center justify-center w-12 h-12 rounded-full border-4 border-white bg-amber-500 text-white font-bold shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-md relative z-10">
							2
						</div>
						<div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] p-6 bg-white rounded-2xl shadow-sm border border-gray-100">
							<h3 class="font-bold text-gray-900 text-lg mb-2">Application</h3>
							<p class="text-gray-600 text-sm">After your tour, we will provide you with the official enrollment packet and dietary requirement forms.</p>
						</div>
					</div>

					<div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
						<div class="flex items-center justify-center w-12 h-12 rounded-full border-4 border-white bg-rose-500 text-white font-bold shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-md relative z-10">
							3
						</div>
						<div class="w-[calc(100%-4rem)] md:w-[calc(50%-3rem)] p-6 bg-white rounded-2xl shadow-sm border border-gray-100">
							<h3 class="font-bold text-gray-900 text-lg mb-2">Welcome Home!</h3>
							<p class="text-gray-600 text-sm">Secure your spot, meet the educators, and get ready for your child's first day at èmote academy.</p>
						</div>
					</div>
				</div>
			</div>

			<div class="lg:col-span-7 bg-white rounded-3xl p-8 md:p-10 border border-gray-100 shadow-xl shadow-teal-900/5 h-fit">
				<h2 class="text-2xl font-bold text-teal-900 mb-2">Request Enrollment Info</h2>
				<p class="text-gray-500 mb-8">Tell us a little bit about your child, and we will be in touch shortly.</p>
				
				<form action="https://api.web3forms.com/submit" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-5">
					
					<input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">
					
					<input type="checkbox" name="botcheck" class="hidden" style="display: none;">
					<input type="hidden" name="subject" value="NEW ADMISSIONS INQUIRY - èmote academy">

					<div class="md:col-span-1 flex flex-col">
						<label for="parentName" class="text-sm font-semibold text-gray-700 mb-2">Parent/Guardian Name *</label>
						<input type="text" id="parentName" name="Parent Name" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white" required>
					</div>
					
					<div class="md:col-span-1 flex flex-col">
						<label for="phone" class="text-sm font-semibold text-gray-700 mb-2">Phone Number *</label>
						<input type="tel" id="phone" name="Phone Number" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white" required>
					</div>

					<div class="md:col-span-2 flex flex-col">
						<label for="email" class="text-sm font-semibold text-gray-700 mb-2">Email Address *</label>
						<input type="email" id="email" name="Email" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white" required>
					</div>

					<div class="md:col-span-1 flex flex-col">
						<label for="childAge" class="text-sm font-semibold text-gray-700 mb-2">Child's Age *</label>
						<input type="text" id="childAge" name="Child Age" placeholder="e.g. 3 years, 4 months" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white" required>
					</div>

					<div class="md:col-span-1 flex flex-col">
						<label for="startDate" class="text-sm font-semibold text-gray-700 mb-2">Desired Start Date</label>
						<input type="date" id="startDate" name="Desired Start Date" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white">
					</div>

					<div class="md:col-span-2 flex flex-col">
						<label for="program" class="text-sm font-semibold text-gray-700 mb-2">Program of Interest *</label>
						<select id="program" name="Program of Interest" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white bg-no-repeat appearance-none" style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23115e59%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-position: right 1rem top 50%; background-size: 0.65rem auto;" required>
							<option value="" disabled selected>Select a program...</option>
							<option value="Pre-K (Full Day)">Pre-K (Full Day)</option>
							<option value="Evening Program">Evening Program</option>
							<option value="Not Sure Yet">Not Sure Yet</option>
						</select>
					</div>

					<div class="md:col-span-2 flex flex-col">
						<label for="message" class="text-sm font-semibold text-gray-700 mb-2">Any specific needs or questions?</label>
						<textarea id="message" name="Additional Questions" rows="3" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition bg-gray-50 focus:bg-white resize-none"></textarea>
					</div>

					<div class="md:col-span-2">
						<button type="submit" class="w-full py-4 mt-2 bg-rose-500 text-white rounded-xl font-bold text-lg hover:bg-rose-600 transition shadow-md">
							Submit Inquiry
						</button>
					</div>
				</form>
			</div>

		</div>
	</section>

</Layout>