---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Admissions & Enrollment | èmote academy San Antonio" description="Begin your child's journey at èmote academy. Schedule a tour and secure your spot.">
	
	<section class="bg-teal-900 py-20 text-center px-6">
		<div class="max-w-3xl mx-auto">
			<h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-6">
				Join Our <span class="text-amber-400">Family</span>
			</h1>
			<p class="text-xl text-teal-100 leading-relaxed">
				Take the first step toward a nurturing, screen-free educational experience.
			</p>
		</div>
	</section>

	<section class="py-20 px-6 bg-slate-50 flex-grow">
		<div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16">
			
			<div class="lg:col-span-5">
				<h2 class="text-3xl font-bold text-teal-900 mb-8">The Enrollment Process</h2>
				<div class="space-y-8">
					<div class="p-6 bg-white rounded-2xl shadow-sm border-l-4 border-teal-600">
						<h3 class="font-bold text-gray-900 text-lg">1. Inquire & Tour</h3>
						<p class="text-gray-600 text-sm">Fill out the form below. We'll schedule a tour of our San Antonio facility.</p>
					</div>
					<div class="p-6 bg-white rounded-2xl shadow-sm border-l-4 border-amber-500">
						<h3 class="font-bold text-gray-900 text-lg">2. Application</h3>
						<p class="text-gray-600 text-sm">After your tour, we will provide the official enrollment packet.</p>
					</div>
					<div class="p-6 bg-white rounded-2xl shadow-sm border-l-4 border-rose-500">
						<h3 class="font-bold text-gray-900 text-lg">3. Welcome Home!</h3>
						<p class="text-gray-600 text-sm">Secure your spot and get ready for the first day at èmote academy.</p>
					</div>
				</div>
			</div>

			<div class="lg:col-span-7 bg-white rounded-3xl p-8 md:p-10 border border-gray-100 shadow-xl">
				<h2 class="text-2xl font-bold text-teal-900 mb-2">Request Enrollment Info</h2>
				<p class="text-gray-500 mb-8">Tell us about your child, and we will be in touch shortly.</p>
				
				<form action="https://api.web3forms.com/submit" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-5">
					
					<input type="hidden" name="access_key" value="a1b8aaad-759e-4776-9973-3e826b05be78">
					
					<input type="hidden" name="subject" value="New Enrollment Inquiry - Emote Academy">
					
					<input type="hidden" name="from_name" value="Emote Academy Website">

					<div class="md:col-span-1 flex flex-col">
						<label for="parentName" class="text-sm font-semibold text-gray-700 mb-2">Parent Name *</label>
						<input type="text" name="name" id="parentName" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 outline-none bg-gray-50" required>
					</div>
					
					<div class="md:col-span-1 flex flex-col">
						<label for="phone" class="text-sm font-semibold text-gray-700 mb-2">Phone Number *</label>
						<input type="tel" name="phone" id="phone" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 outline-none bg-gray-50" required>
					</div>

					<div class="md:col-span-2 flex flex-col">
						<label for="email" class="text-sm font-semibold text-gray-700 mb-2">Email Address *</label>
						<input type="email" name="email" id="email" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 outline-none bg-gray-50" required>
					</div>

					<div class="md:col-span-1 flex flex-col">
						<label for="childAge" class="text-sm font-semibold text-gray-700 mb-2">Child's Age *</label>
						<input type="text" name="child_age" id="childAge" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 outline-none bg-gray-50" required>
					</div>

					<div class="md:col-span-1 flex flex-col">
						<label for="program" class="text-sm font-semibold text-gray-700 mb-2">Program *</label>
						<select name="program" id="program" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 outline-none bg-gray-50 appearance-none" required>
							<option value="" disabled selected>Select a program...</option>
							<option value="Pre-K (Full Day)">Pre-K (Full Day)</option>
							<option value="Evening Program">Evening Program</option>
							<option value="Spring Break (Ages 3-5)">Spring Break (Ages 3-5)</option>
							<option value="Spring Break (Ages 6-11)">Spring Break (Ages 6-11)</option>
						</select>
					</div>

					<div class="md:col-span-2 flex flex-col">
						<label for="message" class="text-sm font-semibold text-gray-700 mb-2">Message</label>
						<textarea name="message" id="message" rows="3" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-teal-500 outline-none bg-gray-50 resize-none"></textarea>
					</div>

					<div class="md:col-span-2">
						<button type="submit" class="w-full py-4 mt-2 bg-rose-500 text-white rounded-xl font-bold text-lg hover:bg-rose-600 transition shadow-md">
							Submit Inquiry
						</button>
					</div>
				</form>
			</div>

		</div>
	</section>

</Layout>