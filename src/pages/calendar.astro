---
import Layout from '../layouts/Layout.astro';

// You can easily add or edit dates here in the future!
const holidays = [
  { month: "Sep", days: "1", event: "Labor Day", status: "Closed", color: "rose", desc: "Facility closed for the holiday." },
  { month: "Oct", days: "13", event: "Staff Development", status: "Closed", color: "amber", desc: "No students. Educator training day." },
  { month: "Nov", days: "11", event: "Veterans Day", status: "Closed", color: "rose", desc: "Facility closed for the holiday." },
  { month: "Nov", days: "24-28", event: "Thanksgiving Break", status: "Closed", color: "rose", desc: "Facility closed for the holiday week." },
  { month: "Dec", days: "22-2", event: "Winter Break", status: "Closed", color: "teal", desc: "Facility closed. Classes resume Jan 3." },
  { month: "Jan", days: "19", event: "MLK Jr. Day", status: "Closed", color: "rose", desc: "Facility closed for the holiday." },
  { month: "Feb", days: "16", event: "Presidents' Day", status: "Closed", color: "rose", desc: "Facility closed for the holiday." },
  { month: "Mar", days: "9-13", event: "Spring Break", status: "Camp Open", color: "amber", desc: "STEAM on Stage! Spring Break Camp in session." },
  { month: "Apr", days: "10", event: "Good Friday", status: "Closed", color: "rose", desc: "Facility closed for the holiday." },
  { month: "May", days: "25", event: "Memorial Day", status: "Closed", color: "rose", desc: "Facility closed for the holiday." },
  { month: "Jun", days: "19", event: "Juneteenth", status: "Closed", color: "rose", desc: "Facility closed for the holiday." },
  { month: "Jul", days: "4", event: "Independence Day", status: "Closed", color: "rose", desc: "Facility closed for the holiday." },
];
---

<Layout title="School Calendar | èmote academy San Antonio" description="View our holiday schedule and important dates for the school year.">
	
<section class="bg-teal-900 py-24 text-center px-6 relative overflow-hidden">
		
		<div class="absolute inset-0 z-0 pointer-events-none">
			<div class="absolute -top-4 -left-4 opacity-[0.07] rotate-12">
				<svg class="w-40 h-40 text-white" fill="currentColor" viewBox="0 0 24 24">
					<path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10z"/>
				</svg>
			</div>
			<div class="absolute -bottom-6 -right-6 opacity-[0.07] -rotate-12">
				<svg class="w-48 h-48 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
					<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.2 14.2L11 13V7h1.5v5.2l4.5 2.7-.8 1.3z"/>
				</svg>
			</div>
		</div>

		<div class="max-w-3xl mx-auto relative z-10">
			<span class="bg-white/10 text-white px-4 py-1.5 rounded-full text-sm font-bold tracking-wider uppercase mb-6 inline-block backdrop-blur-sm">2025 - 2026</span>
			<h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-6">
				School <span class="text-amber-400">Calendar</span>
			</h1>
			<p class="text-xl text-teal-50/90 leading-relaxed font-medium">
				Plan ahead with our holiday closures and special camp dates.
			</p>
		</div>
	</section>

	<section class="py-20 px-6 bg-slate-50 flex-grow">
		<div class="max-w-4xl mx-auto">
			
			<div class="flex flex-col gap-5">
				{holidays.map((item) => (
					<div class="group flex flex-col md:flex-row md:items-center gap-5 md:gap-8 bg-white p-5 md:p-6 rounded-3xl shadow-sm border border-gray-100 hover:shadow-lg hover:border-teal-100 transition-all duration-300">
						
						<div class="flex flex-col items-center justify-center w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-slate-50 group-hover:bg-teal-50 transition-colors shrink-0 border border-slate-100 group-hover:border-teal-200">
							<span class="text-xs md:text-sm font-bold uppercase tracking-widest text-teal-600 mb-1">{item.month}</span>
							<span class="text-2xl md:text-3xl font-extrabold text-teal-950">{item.days}</span>
						</div>
						
						<div class="flex-grow">
							<h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-1">{item.event}</h3>
							<p class="text-gray-500 text-sm md:text-base">{item.desc}</p>
						</div>
						
						<div class="shrink-0 mt-2 md:mt-0">
							<span class={`inline-flex items-center justify-center px-4 py-2 rounded-xl text-sm font-bold w-full md:w-auto
								${item.color === 'rose' ? 'bg-rose-50 text-rose-600 border border-rose-100' : ''}
								${item.color === 'amber' ? 'bg-amber-50 text-amber-700 border border-amber-100' : ''}
								${item.color === 'teal' ? 'bg-teal-50 text-teal-700 border border-teal-100' : ''}
							`}>
								{item.status}
							</span>
						</div>

					</div>
				))}
			</div>

			<div class="mt-12 p-8 bg-white rounded-3xl border border-amber-100 shadow-sm flex items-start gap-5">
				<div class="w-12 h-12 bg-amber-50 rounded-full flex items-center justify-center shrink-0 text-amber-500">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
				</div>
				<div>
					<h4 class="text-lg font-bold text-gray-900 mb-2">Inclement Weather Policy</h4>
					<p class="text-gray-600 leading-relaxed text-sm md:text-base">
						In the event of extreme weather, èmote academy generally follows the local San Antonio closure schedule for safety. Parents will be notified of any unscheduled closures via email and direct text message.
					</p>
				</div>
			</div>

		</div>
	</section>
</Layout>