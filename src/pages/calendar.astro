---
import Layout from '../layouts/Layout.astro';

const firstHalf = [
  { date: "September 1", name: "Labor Day", status: "Closed" },
  { date: "October 13", name: "Staff Development", status: "Closed" },
  { date: "November 11", name: "Veterans Day", status: "Closed" },
  { date: "Nov 24 - 28", name: "Thanksgiving Break", status: "Closed" },
  { date: "Dec 22 - Jan 2", name: "Winter Break", status: "Closed" },
  { date: "January 19", name: "MLK Jr. Day", status: "Closed" },
  { date: "February 16", name: "Presidents' Day", status: "Closed" },
];

const secondHalf = [
  { date: "March 9 - 13", name: "Spring Break", status: "Camp Open", color: "amber" },
  { date: "April 10", name: "Good Friday", status: "Closed" },
  { date: "May 25", name: "Memorial Day", status: "Closed" },
  { date: "June 19", name: "Juneteenth", status: "Closed" },
  { date: "July 4", name: "Independence Day", status: "Closed" },
];
---

<Layout title="School Calendar | èmote academy San Antonio" description="View our 2025-2026 schedule of holidays, breaks, and special events.">
	
	<section class="bg-teal-900 py-24 text-center px-6">
		<div class="max-w-4xl mx-auto">
			<span class="bg-white/20 text-white px-4 py-1.5 rounded-full text-sm font-bold tracking-wider uppercase mb-6 inline-block">2025 - 2026</span>
			<h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-6">
				School <span class="text-amber-400">Calendar</span>
			</h1>
			<p class="text-xl text-teal-50 leading-relaxed max-w-2xl mx-auto font-medium">
				Plan ahead with our holiday closures and special camp dates.
			</p>
		</div>
	</section>

	<section class="py-20 px-6 bg-slate-50 flex-grow">
		<div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
			
			<div class="bg-white p-10 rounded-3xl shadow-lg border-t-8 border-teal-500">
				<div class="inline-block bg-teal-100 text-teal-800 font-bold px-4 py-1.5 rounded-full text-sm mb-6">Term 1</div>
				<h2 class="text-3xl font-bold text-teal-900 mb-8">Fall & Winter</h2>
				
				<ul class="space-y-6">
					{firstHalf.map((item) => (
						<li class="flex items-start gap-4 pb-6 border-b border-gray-100 last:border-0 last:pb-0">
							<div class="shrink-0 mt-1">
								<svg class="w-6 h-6 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
							</div>
							<div class="flex-grow">
								<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-1">
									<span class="text-gray-900 font-bold text-lg">{item.name}</span>
									<span class={`inline-block px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-wider w-fit
										${item.status === 'Closed' ? 'bg-rose-50 text-rose-600' : 'bg-amber-50 text-amber-600'}
									`}>
										{item.status}
									</span>
								</div>
								<span class="text-gray-500 font-medium">{item.date}</span>
							</div>
						</li>
					))}
				</ul>
			</div>

			<div class="bg-white p-10 rounded-3xl shadow-lg border-t-8 border-amber-500 h-fit">
				<div class="inline-block bg-amber-100 text-amber-800 font-bold px-4 py-1.5 rounded-full text-sm mb-6">Term 2</div>
				<h2 class="text-3xl font-bold text-teal-900 mb-8">Spring & Summer</h2>
				
				<ul class="space-y-6">
					{secondHalf.map((item) => (
						<li class="flex items-start gap-4 pb-6 border-b border-gray-100 last:border-0 last:pb-0">
							<div class="shrink-0 mt-1">
								<svg class={`w-6 h-6 ${item.color === 'amber' ? 'text-amber-500' : 'text-teal-500'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
							</div>
							<div class="flex-grow">
								<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-1">
									<span class="text-gray-900 font-bold text-lg">{item.name}</span>
									<span class={`inline-block px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-wider w-fit
										${item.status === 'Closed' ? 'bg-rose-50 text-rose-600' : 'bg-amber-50 text-amber-600'}
									`}>
										{item.status}
									</span>
								</div>
								<span class="text-gray-500 font-medium">{item.date}</span>
							</div>
						</li>
					))}
				</ul>
			</div>

		</div>

		<div class="max-w-4xl mx-auto mt-16 p-6 bg-white rounded-2xl border border-gray-100 shadow-sm flex items-start gap-4">
			<svg class="w-6 h-6 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
			<p class="text-gray-600 leading-relaxed text-sm">
				<strong>Inclement Weather:</strong> èmote academy follows the San Antonio ISD closure schedule for severe weather. Parents will be notified of any unscheduled closures via email and direct text message.
			</p>
		</div>
	</section>

</Layout>