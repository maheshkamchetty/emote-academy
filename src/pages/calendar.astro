---
import Layout from '../layouts/Layout.astro';

const seasons = [
  {
    title: "Fall Term",
    theme: "bg-orange-50 border-orange-100 text-orange-800",
    iconColor: "text-orange-500",
    events: [
      { date: "Sep 1", name: "Labor Day", status: "Closed" },
      { date: "Oct 13", name: "Staff Development", status: "Closed" },
      { date: "Nov 11", name: "Veterans Day", status: "Closed" },
      { date: "Nov 24-28", name: "Thanksgiving Break", status: "Closed" },
    ]
  },
  {
    title: "Winter Term",
    theme: "bg-blue-50 border-blue-100 text-blue-800",
    iconColor: "text-blue-500",
    events: [
      { date: "Dec 22 - Jan 2", name: "Winter Break", status: "Closed" },
      { date: "Jan 19", name: "MLK Jr. Day", status: "Closed" },
      { date: "Feb 16", name: "Presidents' Day", status: "Closed" },
    ]
  },
  {
    title: "Spring Term",
    theme: "bg-teal-50 border-teal-100 text-teal-800",
    iconColor: "text-teal-500",
    events: [
      { date: "Mar 9-13", name: "Spring Break", status: "Camp Open" },
      { date: "Apr 10", name: "Good Friday", status: "Closed" },
      { date: "May 25", name: "Memorial Day", status: "Closed" },
    ]
  },
  {
    title: "Summer Term",
    theme: "bg-amber-50 border-amber-100 text-amber-800",
    iconColor: "text-amber-500",
    events: [
      { date: "Jun 19", name: "Juneteenth", status: "Closed" },
      { date: "Jul 4", name: "Independence Day", status: "Closed" },
    ]
  }
];
---

<Layout title="Academic Calendar | èmote academy San Antonio" description="View our 2025-2026 schedule of holidays, breaks, and special events.">
	
	<section class="bg-white pt-20 pb-10 px-6 text-center">
		<div class="max-w-3xl mx-auto">
			<div class="inline-flex items-center justify-center bg-teal-50 text-teal-700 font-bold px-4 py-1.5 rounded-full text-sm mb-6 uppercase tracking-widest border border-teal-100">
				2025 - 2026 Academic Year
			</div>
			<h1 class="text-4xl md:text-5xl font-extrabold text-teal-950 tracking-tight mb-4">
				School <span class="text-amber-500">Calendar</span>
			</h1>
			<p class="text-gray-500 text-lg">
				A quick, at-a-glance view of our holiday closures and special camps.
			</p>
		</div>
	</section>

	<section class="py-12 px-6 bg-white flex-grow">
		<div class="max-w-5xl mx-auto">
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
				
				{seasons.map((season) => (
					<div class={`rounded-3xl p-8 md:p-10 border shadow-sm transition-transform hover:-translate-y-1 duration-300 ${season.theme}`}>
						
						<div class="flex items-center justify-between mb-8 border-b border-black/5 pb-4">
							<h2 class="text-2xl font-extrabold tracking-tight">{season.title}</h2>
							<svg class={`w-8 h-8 opacity-70 ${season.iconColor}`} fill="currentColor" viewBox="0 0 24 24">
								<circle cx="12" cy="12" r="10" opacity="0.2"/>
								<path d="M12 6v6l4 2"/>
							</svg>
						</div>

						<ul class="space-y-6">
							{season.events.map((item) => (
								<li class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 sm:gap-4">
									
									<div class="flex items-center gap-3">
										<span class="font-bold text-gray-900 w-24 shrink-0">{item.date}</span>
										<span class="text-gray-700 font-medium">{item.name}</span>
									</div>

									<div class="sm:text-right mt-1 sm:mt-0">
										<span class={`inline-block px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider
											${item.status === 'Closed' ? 'bg-black/5 text-gray-700' : 'bg-white text-teal-700 shadow-sm border border-black/5'}
										`}>
											{item.status}
										</span>
									</div>

								</li>
							))}
						</ul>
					</div>
				))}

			</div>

			<div class="mt-12 p-6 bg-slate-50 rounded-2xl border border-slate-100 flex flex-col sm:flex-row items-center justify-center gap-3 text-center sm:text-left text-slate-500 text-sm">
				<svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
				<p>We observe San Antonio ISD emergency weather closures. Parents will be notified via SMS.</p>
			</div>

		</div>
	</section>
</Layout>