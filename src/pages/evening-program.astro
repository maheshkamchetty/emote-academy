---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Evening Program | èmote academy San Antonio" description="Flexible evening childcare in San Antonio designed for working parents. A safe, screen-free environment with engaging activities and healthy meals.">
	
	<section class="bg-indigo-950 py-20 text-center px-6">
		<div class="max-w-3xl mx-auto">
			<h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-6">
				Evening <span class="text-amber-300">Adventures</span>
			</h1>
			<p class="text-xl text-indigo-200 leading-relaxed">
				Flexible, nurturing evening care designed to support working parents while keeping your child engaged in a screen-free environment.
			</p>
		</div>
	</section>

	<section class="py-20 px-6 bg-slate-50 flex-grow">
		<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
			
			<div>
				<h2 class="text-3xl font-bold text-teal-900 mb-6">Peace of Mind After Hours</h2>
				<p class="text-gray-600 text-lg leading-relaxed mb-6">
					We understand that the standard 9-to-5 doesn't work for every family. Our Evening Adventures program offers a seamless extension of our daytime philosophy, providing a safe and engaging space for your child while you work or take time to recharge.
				</p>
				<ul class="space-y-4 text-gray-700 font-medium">
					<li class="flex items-center gap-3">
						<svg class="w-6 h-6 text-teal-600 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
						Healthy, allergen-friendly evening meals
					</li>
					<li class="flex items-center gap-3">
						<svg class="w-6 h-6 text-teal-600 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
						Screen-free wind-down activities
					</li>
					<li class="flex items-center gap-3">
						<svg class="w-6 h-6 text-teal-600 fill-current" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
						Storytime, dramatic play, and quiet crafts
					</li>
				</ul>
			</div>

			<div class="bg-indigo-50 p-8 rounded-3xl border border-indigo-100 shadow-sm">
				<h3 class="text-2xl font-bold text-indigo-950 mb-4">Schedule a Visit</h3>
				<p class="text-indigo-800 mb-8">We would love to show you our facility and discuss how our evening program can fit your family's unique schedule.</p>
				<a href="/admissions" class="block w-full text-center py-4 bg-teal-700 text-white rounded-xl font-bold text-lg hover:bg-teal-800 transition shadow-md">
					Inquire About Enrollment
				</a>
			</div>

		</div>
	</section>

</Layout>